# ─── Resonaite Environment Configuration ─────────────
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=resonaite-dev-secret-change-me

# ─── Google Cloud Storage (audio files) ──────────────
GCS_ENABLED=true
GCS_BUCKET=resonaite-audio-1771065297
GCS_PROJECT_ID=wastenot-216406
# Path to your service account JSON key file (download from GCP Console)
# Leave empty to use Application Default Credentials (gcloud auth)
GCS_KEY_PATH=

# ─── Gemini API (prompt processing + enhancement) ────
GEMINI_API_KEY=AIzaSyA9t3s1xMwSt4Kbyws8rTfg7mXgt36bQPQ

# ─── Suno AI (music generation via api.kie.ai) ──────
SUNO_API_KEY=c63f80005f128320a37e70dadae6a7f7
SUNO_MODEL=V5

# ─── Google Cloud — Lyria 2 (legacy, kept for reference) ──
LYRIA_ENABLED=false
GCP_PROJECT_ID=wastenot-216406
GCP_REGION=us-central1
