# Resonaite Server Configuration
# ================================
# Copy this file to .env and customize for your environment

# Server Configuration
PORT=3001
NODE_ENV=development

# ================================
# Authentication & Security
# ================================
# JWT secret for signing authentication tokens
# IMPORTANT: Change this to a random string in production!
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-string-in-production
JWT_EXPIRY=7d

# ================================
# Database
# ================================
# Path to SQLite database file
DATABASE_PATH=./db/resonaite.db

# ================================
# Google Lyria 2 Music Generation
# ================================
# Enable AI music generation with Google's Lyria 2 model
# Default: false (uses mock generation with test audio files)
# Set to true to enable real API calls
LYRIA_ENABLED=false

# Your Google Cloud Project ID
# Get this from: https://console.cloud.google.com
GCP_PROJECT_ID=your-project-id-here

# GCP region for Vertex AI API
# Common choices: us-central1, europe-west1, asia-southeast1
GCP_REGION=us-central1

# Path to GCP service account JSON key file
# Download from: GCP Console > Service Accounts > Create Key > JSON
# Place file in project root and reference it here
GCP_CREDENTIALS_PATH=./gcp-service-account.json

# ================================
# CIM Pipeline Configuration
# ================================
# Python executable path (use python3 or python depending on your system)
PYTHON_PATH=python3

# Path to the Resonaite Modulation package
# This should point to the resonaite_modulation directory
CIM_PIPELINE_PATH=./python/resonaite_modulation

# ================================
# LYRIA 2 SETUP INSTRUCTIONS
# ================================
# 1. If LYRIA_ENABLED=false (default):
#    - No GCP setup required, uses test audio files
#    - Good for development/demo purposes
#
# 2. To enable LYRIA_ENABLED=true and use real API:
#    a. Create GCP Project:
#       - Go to https://console.cloud.google.com
#       - Create new project or use existing
#
#    b. Enable Vertex AI API:
#       - In GCP Console, search for "Vertex AI API"
#       - Enable it for your project
#
#    c. Create Service Account:
#       - Go to IAM & Admin > Service Accounts
#       - Create new service account
#       - Give it the "Vertex AI User" role
#       - Create JSON key and download
#
#    d. Configure Environment:
#       - Copy the JSON key to your project
#       - Update GCP_PROJECT_ID with your project ID
#       - Update GCP_CREDENTIALS_PATH to point to the JSON file
#       - Set LYRIA_ENABLED=true
#
#    e. Test the API:
#       - Check GCP quotas and billing are configured
#       - Make a test request
